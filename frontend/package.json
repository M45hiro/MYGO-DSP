{
  "name": "mygo-dsp-frontend",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "antd": "^6.4.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.mygo.dsp",
    "productName": "MYGO-DSP",
    "files": [
      "dist/**/*",
      "electron/**/*.cjs"
    ],
    "extraResources": [
      {
        "from": "../dsp-core/build/mygo_dsp_engine.exe",
        "to": "dsp/mygo_dsp_engine.exe"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "icon": null
    }
  }
}
